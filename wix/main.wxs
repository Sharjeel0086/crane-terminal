<?xml version='1.0' encoding='windows-1252'?>
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
    <Product
        Id='*'
        Name='Crane'
        UpgradeCode='6EADAEB6-B7E2-4C1F-879E-2A4004944933'
        Manufacturer='Crane Team'
        Language='1033'
        Codepage='1252'
        Version='0.4.59'>

        <Package Id='*'
            Keywords='Installer'
            Description='Crane native code editor'
            Manufacturer='Crane Team'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='crane.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='Crane Installation [1]'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='ProgramFiles64Folder' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='Crane'>
                    <Component Id='License' Guid='*'>
                        <File Id='LicenseFile' Name='LICENSE' DiskId='1' Source='LICENSE' KeyPath='yes'/>
                    </Component>
                    
                    <Directory Id='Bin' Name='bin'>
                        <Component Id='Path' Guid='8C6AD3CC-8A7B-4A1C-9853-2F453B0BEE60' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>
                        <Component Id='crane.exe' Guid='*'>
                            <File
                                Id='crane.exe'
                                Name='crane.exe'
                                DiskId='1'
                                Source='target\release\crane.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>
            
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="Crane"/>
            </Directory>
        </Directory>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="9BD14E3F-729B-4D24-814E-0A4C80EF1E3A">
                <Shortcut Id="ApplicationStartMenuShortcut"
                          Name="Crane"
                          Description="The Crane Code Editor"
                          Target="[#crane.exe]"
                          WorkingDirectory="APPLICATIONFOLDER"/>
                <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\Crane" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </DirectoryRef>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the crane executable and license.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            <ComponentRef Id='License'/>
            <ComponentRef Id='crane.exe'/>
            <ComponentRef Id='ApplicationShortcut' />
            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Adds the crane executable directory to the PATH environment variable.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>
    </Product>
</Wix>
